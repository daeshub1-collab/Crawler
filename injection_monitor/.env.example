# .env.example — 이 파일을 복사해 .env 로 저장하고 값을 채우세요
# cp .env.example .env

# ── 필수 ──────────────────────────────────────────────────────────────────────
MAIL_TO=your@email.com

# ── 선택 ──────────────────────────────────────────────────────────────────────
MAIL_SUBJECT=[사출기 모니터링] 주간 공고 알림

# 스케줄 (기본: 매주 월요일 09:00)
SCHEDULE_DAY=monday
SCHEDULE_TIME=09:00

# 크롤링 타임아웃 (초)
FETCH_TIMEOUT=15
FETCH_RETRY=2
SELENIUM_WAIT=20
